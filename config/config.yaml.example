# OpenClaw 数据生成项目配置文件
# 使用方法: cp config/config.yaml.example config/config.yaml
# 然后修改 config.yaml 中的配置项

# ============== OpenClaw 配置 ==============
openclaw:
  # 仅用于说明默认主 agent，实际生成使用 worker_prefix + 序号
  base_agent: "main"

  # worker agent 前缀，例如 gendata-worker-1 ~ gendata-worker-30
  worker_prefix: "gendata-worker"

  # 默认并发 worker 数
  num_workers: 5

  # OpenClaw thinking 级别，可选 off|minimal|low|medium|high|xhigh
  thinking: "off"

# ============== LLM API 配置 ==============
llm:
  # LLM API 基础URL
  # 示例: Azure OpenAI: "https://your-resource.openai.azure.com"
  # 示例: DeepSeek: "https://api.deepseek.com"
  base_url: "${LLM_BASE_URL}"
  
  # API Key（建议使用环境变量）
  api_key: "${LLM_API_KEY}"
  
  # 模型名称
  model: "gpt-4o-2024-11-20"
  
  # 温度参数（控制随机性，0-2）
  temperature: 0.7
  
  # 最大生成 token 数
  max_tokens: 4000
  
  # 请求超时时间（秒）
  timeout: 120

# ============== 生成配置 ==============
generation:
  # 最大交互轮次（保险丝，避免 User Loop 死循环）
  max_turns: 20

  # 单次 OpenClaw 交互超时（秒）
  timeout: 600

# ============== 路径配置 ==============
paths:
  # Intent 数据文件路径
  intents_file: "data_examples/intents.jsonl"
  
  # 输出根目录
  output_dir: "output"
  
  # 归档后的 session jsonl 输出目录
  sessions_dir: "output/sessions"
  
  # 中间格式输出目录
  middle_format_dir: "output/middle_format"
  
  # 进度文件
  progress_file: "output/progress.json"
  
  # 日志目录
  logs_dir: "output/logs"
  
  # 工具 catalog 缓存文件；主流程会优先读取，没有时自动调用 tools/fetch_tools/dump_tools.mjs 生成
  tools_cache_file: "output/tools/openclaw_all_tools.json"
