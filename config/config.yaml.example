
# ============== OpenClaw 配置 ==============
openclaw:
  worker_prefix: "gendata-worker"
  workspace_root: "~/.openclaw/workspaces"
  num_workers: 3
  enable_thinking: true            # 是否开启推理模式（true/false）
  worker_tools_allow:
    - "read"
    - "write"
    - "edit"
    - "apply_patch"
    - "exec"
    - "process"
    - "web_search"
    - "web_fetch"
    - "memory_search"
    - "memory_get"
    - "sessions_list"
    - "sessions_history"
    - "sessions_send"
    - "sessions_spawn"
    - "session_status"
    - "subagents"
    - "agents_list"
    - "image"
    - "tts"
  model_url: "xxx"
  model_api_key: "xxx"
  model: "claude-sonnet-4-6"
  api: "openai-completions"     # openai-completions / anthropic-messages
  context_window: 360000 
  max_tokens: 36000


# ============== LLM API 配置 ==============
llm:
  base_url: "xxx"
  api_key: "xxx"
  model: "gpt-4o-2024-11-20"
  temperature: 0.7
  max_tokens: 36000
  timeout: 120
  retry_attempts: 3
  retry_base_delay: 1.0
  retry_max_delay: 8.0
  enable_thinking: true           # 是否开启推理模式（默认 true）

# ============== 生成配置 ==============
generation:
  # 最大交互轮次（保险丝，避免 User Loop 死循环）
  max_turns: 20

  # 单次 OpenClaw 交互超时（秒）
  timeout: 600

# ============== 路径配置 ==============
paths:
  intents_file: "data_examples/intents.jsonl"   # Intent 数据文件路径
  output_dir: "output"                          # 输出根目录
  sessions_dir: "output/sessions"               # 归档后的 session jsonl 输出目录
  middle_format_dir: "output/middle_format"     # 中间格式输出目录
  progress_file: "output/progress.json"         # 进度文件
  logs_dir: "output/logs"                       # 日志目录
  
  # 工具 catalog 缓存文件；按 agent 分组存储 {agent_id: [tools]}
  # 使用 init_agents.py --refresh-tools 生成
  # 注意：文件名可以是任意名称，实际配置使用 openclaw_all_tools.json
  tools_cache_file: "output/tools/openclaw_all_tools.json"

  # Skills 目录路径
  skills_dir: "tools/skills/skills_collections"
