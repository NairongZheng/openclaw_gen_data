
# 运行时参数优先级：ENV > CLI > config

# ============== OpenClaw 配置 ==============
openclaw:
  worker_prefix: "gendata-worker"
  workspace_root: "~/.openclaw/workspaces"
  num_workers: "${CONCURRENT_NUM:-3}"
  worker_tools_allow:
    - "read"
    - "write"
    - "edit"
    - "apply_patch"
    - "exec"
    - "process"
    - "web_search"
    - "web_fetch"
    - "memory_search"
    - "memory_get"
    - "sessions_list"
    - "sessions_history"
    - "sessions_send"
    - "sessions_spawn"
    - "session_status"
    - "subagents"
    - "agents_list"
    - "image"
    - "tts"
  model_url: "${OPENCLAW_MODEL_URL:-https://your-openclaw-model-endpoint/v1}"
  model_api_key: "${OPENCLAW_MODEL_API_KEY:-your-openclaw-model-api-key}"
  model: "${OPENCLAW_MODEL_NAME:-glm-5}"

  # API 类型：
  api: "openai-completions"     # openai-completions / anthropic-messages

  enable_thinking: true         # 是否开启 OpenClaw 推理模式（true/false）
  # 注意：这里主要控制 session 原始轨迹里是否更容易出现 thinking/reasoning 内容。
  # 即使设成 false，OpenClaw / 底层模型有时仍会在 session 原始消息里留下 type="thinking" 块。
  # 这是 OpenClaw 对模型原始输出的归档行为，不代表你的配置没有生效。

  # Thinking Level 配置：仅当 enable_thinking=true 时才会传给 OpenClaw CLI
  # 可选值：off | minimal | low | medium | high | xhigh | adaptive
  # - Claude 4.6 模型默认使用 adaptive
  # - Z.AI（glm） 只支持二进制（on/off），任何非 off 的值都映射为 low
  thinking_level: "high"
  context_window: 360000
  max_tokens: 36000


# ============== LLM API 配置 ==============
llm:
  base_url: "${LLM_BASE_URL:-https://your-llm-endpoint/v1}"
  api_key: "${LLM_API_KEY:-your-llm-api-key}"
  model: "${LLM_MODEL_NAME:-glm-5}"
  temperature: 0.7
  max_tokens: 36000
  timeout: 120
  retry_attempts: 3
  retry_base_delay: 1.0
  retry_max_delay: 8.0
  enable_thinking: true

# ============== 生成配置 ==============
generation:
  # 最大交互轮次（保险丝，避免 User Loop 死循环）
  max_turns: 20

  # 每个 worker 连续处理多少个 intent 后才重置一次 session / workspace
  intents_per_session: "${INTENTS_PER_SESSION:-1}"

  # 单次 OpenClaw 交互超时（秒）
  timeout: 600

# ============== 路径配置 ==============
paths:
  intents_file: "${INTENTS_FILE:-data_examples/intents.jsonl}"   # Intent 数据文件路径
  output_dir: "output"                          # 输出根目录
  sessions_dir: "output/sessions"               # 归档后的 session jsonl 输出目录
  middle_format_dir: "output/middle_format"     # 中间格式输出目录
  progress_file: "output/progress.json"         # 进度文件
  logs_dir: "output/logs"                       # 日志目录
  
  # 工具 catalog 缓存文件；按 agent 分组存储 {agent_id: [tools]}
  # 使用 init_agents.py --refresh-tools 生成
  # 注意：文件名可以是任意名称，实际配置使用 openclaw_all_tools.json
  tools_cache_file: "output/tools/openclaw_all_tools.json"

  # Skills 目录路径
  skills_dir: "tools/skills/skills_collections"
