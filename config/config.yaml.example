# OpenClaw 数据生成项目配置文件
# 使用方法: cp config/config.yaml.example config/config.yaml
# 然后修改 config.yaml 中的配置项

# ============== OpenClaw 配置 ==============
openclaw:
  worker_prefix: "gendata-worker"
  workspace_root: "~/.openclaw/workspaces"
  num_workers: 3
  thinking: "off"
  model_url: "xxx"
  model_api_key: "xxx"
  model: "claude-sonnet-4-6"
  context_window: 200000 
  max_tokens: 8192 

# ============== LLM API 配置 ==============
llm:
  # LLM API 基础URL
  # 示例: Azure OpenAI: "https://your-resource.openai.azure.com"
  # 示例: DeepSeek: "https://api.deepseek.com"
  base_url: "${LLM_BASE_URL}"
  
  # API Key（建议使用环境变量）
  api_key: "${LLM_API_KEY}"
  
  # 模型名称
  model: "gpt-4o-2024-11-20"
  
  # 温度参数（控制随机性，0-2）
  temperature: 0.7
  
  # 最大生成 token 数
  max_tokens: 4000
  
  # 请求超时时间（秒）
  timeout: 120

# ============== 生成配置 ==============
generation:
  # 最大交互轮次（保险丝，避免 User Loop 死循环）
  max_turns: 20

  # 单次 OpenClaw 交互超时（秒）
  timeout: 600

# ============== 路径配置 ==============
paths:
  # Intent 数据文件路径
  intents_file: "data_examples/intents.jsonl"
  
  # 输出根目录
  output_dir: "output"
  
  # 归档后的 session jsonl 输出目录
  sessions_dir: "output/sessions"
  
  # 中间格式输出目录
  middle_format_dir: "output/middle_format"
  
  # 进度文件
  progress_file: "output/progress.json"
  
  # 日志目录
  logs_dir: "output/logs"
  
  # 工具 catalog 缓存文件；按 agent 分组存储 {agent_id: [tools]}
  # 使用 init_agents.py --refresh-tools 生成
  # 注意：文件名可以是任意名称，实际配置使用 openclaw_all_tools.json
  tools_cache_file: "output/tools/openclaw_all_tools.json"

  # Skills 目录路径
  skills_dir: "tools/skills/skills_collections"
